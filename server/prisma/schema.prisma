generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           String         @id @default(cuid())
  notionId     String         @unique
  title        String
  description  String
  thumbnailUrl String?
  githubUrl    String?
  deployUrl    String?
  startDate    DateTime
  endDate      DateTime?

  // --- Notion Auto Fields (generated) ---
  // (do not edit manually; managed by notion:schema-sync)
  notion_project_수상 String? @map("notionProp_c4902d28e9")
  notion_project_블로그 String? @map("notionProp_a1c5c9ec45")
  // --- Notion Auto Fields End ---

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  posts        PostProject[]
  stacks       ProjectStack[]
  award        Award?
}

model Post {
  id           String        @id @default(cuid())
  notionId     String        @unique
  title        String
  summary      String?
  thumbnailUrl String?
  date         DateTime
  categories   String // JSON array stored as string
  content      String?

  // --- Notion Auto Fields (generated) ---
  // (do not edit manually; managed by notion:schema-sync)
  // --- Notion Auto Fields End ---

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projects     PostProject[]
}

model Stack {
  id        String         @id @default(cuid())
  notionId  String         @unique
  name      String
  imageUrl  String?

  // --- Notion Auto Fields (generated) ---
  // (do not edit manually; managed by notion:schema-sync)
  notion_stack_Projects String? @map("notionProp_e4b8496f87")
  notion_stack_설명 String? @map("설명")
  notion_stack_카테고리 String? @map("카테고리")
  // --- Notion Auto Fields End ---

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  projects  ProjectStack[]
}

model PostProject {
  postId    String
  projectId String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([postId, projectId])
}

model ProjectStack {
  projectId String
  stackId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stack     Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@id([projectId, stackId])
}

model Award {
  id           String   @id @default(cuid())
  notionId     String   @unique
  title        String
  organization String
  date         DateTime
  imageUrl     String?
  projectId    String?  @unique
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // --- Notion Auto Fields (generated) ---
  // (do not edit manually; managed by notion:schema-sync)
  // --- Notion Auto Fields End ---

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
