generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String
  techStack    String // JSON array stored as string
  thumbnailUrl String?
  githubUrl    String?
  deployUrl    String?
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  posts        PostProject[]
}

model Post {
  slug     String        @id
  title    String
  projects PostProject[]
}

model PostProject {
  postSlug  String
  projectId String
  post      Post    @relation(fields: [postSlug], references: [slug], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([postSlug, projectId])
}

model Award {
  id           String   @id @default(cuid())
  title        String
  organization String
  date         DateTime
  description  String?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
